{
  "name": "@editron/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.777.0",
    "@aws-sdk/s3-request-presigner": "3.777.0",
    "@editron/db": "workspace:*",
    "@editron/shared": "workspace:*",
    "@fastify/cors": "^10.0.1",
    "better-auth": "1.6.3",
    "bullmq": "5.73.5",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.2.1",
    "ioredis": "5.6.1",
    "stripe": "22.0.1",
    "zod": "3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "3.2.1"
  }
}
