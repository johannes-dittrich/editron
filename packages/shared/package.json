{
  "name": "@editron/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./r2": {
      "types": "./dist/r2.d.ts",
      "default": "./dist/r2.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "3.2.1"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.777.0",
    "@aws-sdk/s3-request-presigner": "3.777.0",
    "zod": "3.24.4"
  }
}
